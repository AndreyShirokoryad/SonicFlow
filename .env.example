# Local HTTP:
SITE_ADDRESS=:80
PUBLIC_BASE_URL=http://localhost

# Production HTTPS:
# SITE_ADDRESS=playlist.example.com
# PUBLIC_BASE_URL=https://playlist.example.com

GITHUB_URL=https://github.com/your-username/PlaylistAnalyze
CORS_ORIGINS=*

# Host path with exported Item2Vec model files.
HOST_MODEL_DIR=./data/models/item2vec_mpd_gensim

# Container path used by FastAPI.
MODEL_DIR=/models/item2vec_mpd_gensim

# Build a FAISS inner-product index for faster recommendation candidate retrieval.
ENABLE_FAISS=1

# Set to 1 if the container must fail fast when model files are missing.
REQUIRE_MODEL_ON_STARTUP=0
